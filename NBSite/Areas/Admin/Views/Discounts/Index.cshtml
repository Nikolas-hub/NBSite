@using NBSite.Areas.Admin.Models
@model DiscountListVM
@{
    ViewData["Title"] = "Управление скидками";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Добавить скидку
    </a>
</p>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Поиск по названию товара или ID скидки" value="@Model.SearchQuery" />
        <button class="btn btn-outline-secondary" type="submit">Найти</button>
    </div>
</form>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Товар</th>
            <th>Тип</th>
            <th>Значение</th>
            <th>Начало</th>
            <th>Окончание</th>
            <th>Активна</th>
            <th>Приоритет</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.ProductName</td>
                <td>@item.DiscountType</td>
                <td>@item.Value.ToString("F2")</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Да</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Нет</span>
                    }
                </td>
                <td>@item.Priority</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                        <i class="fas fa-edit me-1"></i>Редактировать
                    </a>
                    <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@item.Id)">
                        <i class="fas fa-trash me-1"></i>Удалить
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchQuery">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить скидку?')) {
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("Delete")/' + id;
                form.innerHTML = '@Html.AntiForgeryToken()';
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}