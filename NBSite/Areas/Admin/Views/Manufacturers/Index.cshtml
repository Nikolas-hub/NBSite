@using NBSite.Areas.Admin.Models
@model ManufacturerListVM
@{
    ViewData["Title"] = "Управление производителями";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Добавить производителя
    </a>
</p>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Поиск по названию или коду" value="@Model.SearchQuery" />
        <button class="btn btn-outline-secondary" type="submit">
            <i class="fas fa-search me-1"></i>Найти
        </button>
    </div>
</form>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Изображение</th>
            <th>Название</th>
            <th>Алиас</th>
            <th>Код</th>
            <th>Код страны</th>
            <th>Сортировка</th>
            <th>Активен</th>
            <th>Товаров</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items!)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Image))
                    {
                        <img src="/@item.Image" alt="" style="max-height: 40px;" />
                    }
                </td>
                <td>@item.Name</td>
                <td>@item.Alias</td>
                <td>@item.Code</td>
                <td>@item.CountryCode</td>
                <td>@item.Sort</td>
                <td>
                    @if (item.Active)
                    {
                        <span class="badge bg-success">Да</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Нет</span>
                    }
                </td>
                <td>@item.ProductsCount</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                        <i class="fas fa-edit"></i> Редактировать
                    </a>
                    <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@item.Id, '@item.Name')">
                        <i class="fas fa-trash"></i> Удалить
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchQuery">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            if (confirm(`Удалить производителя "${name}"?`)) {
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("Delete", "Manufacturers", new { area = "Admin" })/' + id;
                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = '__RequestVerificationToken';
                input.value = token;
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}