@using NBSite.Areas.Admin.Models
@model OrderListVM
@{
    ViewData["Title"] = "Управление заказами";
}

<h1>@ViewData["Title"]</h1>

<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Поиск по ID, email, телефону..." value="@Model.SearchQuery" />
                <button class="btn btn-outline-secondary" type="submit">
                    <i class="fas fa-search"></i> Найти
                </button>
            </div>
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select" onchange="this.form.submit()">
                @foreach (var item in ViewBag.Statuses)
                {
                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                }
            </select>
        </div>
    </div>
</form>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>№ заказа</th>
            <th>Дата</th>
            <th>Статус</th>
            <th>Получатель</th>
            <th>Email</th>
            <th>Телефон</th>
            <th>Сумма</th>
            <th>Товаров</th>
            <th>Доставка</th>
            <th>Оплата</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items!)
        {
            <tr>
                <td>@item.Id</td>
                <td>@(item.SubmittedAt?.ToString("dd.MM.yyyy HH:mm") ?? item.CreatedAt.ToString("dd.MM.yyyy HH:mm"))</td>
                <td><span class="badge @(GetStatusBadgeClass(item.StatusValue))">@item.Status</span></td>
                <td>@item.Reciever</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
                <td>@item.Total.ToString("C")</td>
                <td>@item.ItemsCount</td>
                <td>@item.DeliveryName</td>
                <td>@item.PaymentName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                        <i class="fas fa-eye"></i> Просмотр
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchQuery" asp-route-status="@Model.StatusFilter">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@functions {
    string GetStatusBadgeClass(int status)
    {
        return status switch
        {
            1 => "bg-primary",    // Оформлен
            2 => "bg-success",    // Оплачен
            3 => "bg-warning text-dark", // Отправлен
            4 => "bg-success",    // Доставлен
            5 => "bg-danger",     // Отменён
            _ => "bg-secondary"
        };
    }
}