@using NBSite.Areas.Admin.Models

@model ProductEditVM
@{
    ViewData["Title"] = "Редактирование товара";
}

<h1>@ViewData["Title"]</h1>

<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Alias" class="control-label"></label>
                <input asp-for="Alias" class="form-control" />
                <span asp-validation-for="Alias" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Price" class="control-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="OldPrice" class="control-label"></label>
                        <input asp-for="OldPrice" class="form-control" />
                        <span asp-validation-for="OldPrice" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Quantity" class="control-label"></label>
                        <input asp-for="Quantity" class="form-control" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Multiplicity" class="control-label"></label>
                        <input asp-for="Multiplicity" class="form-control" />
                        <span asp-validation-for="Multiplicity" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="control-label"></label>
                <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories">
                    <option value="">-- Не выбрано --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ManufacturerId" class="control-label"></label>
                <select asp-for="ManufacturerId" class="form-control" asp-items="ViewBag.Manufacturers">
                    <option value="">-- Не выбрано --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Introtext" class="control-label"></label>
                <textarea asp-for="Introtext" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Content" class="control-label"></label>
                <textarea asp-for="Content" class="form-control" rows="5"></textarea>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Volume" class="control-label"></label>
                        <input asp-for="Volume" class="form-control" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Weight" class="control-label"></label>
                        <input asp-for="Weight" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Ean13" class="control-label"></label>
                <input asp-for="Ean13" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="ExpirationDate" class="control-label"></label>
                <input asp-for="ExpirationDate" class="form-control" type="date" />
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="form-check mb-3">
                        <input asp-for="New" class="form-check-input" />
                        <label asp-for="New" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check mb-3">
                        <input asp-for="Popular" class="form-check-input" />
                        <label asp-for="Popular" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check mb-3">
                        <input asp-for="Active" class="form-check-input" />
                        <label asp-for="Active" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check mb-3">
                        <input asp-for="HasReject" class="form-check-input" />
                        <label asp-for="HasReject" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Текущее изображение</label><br />
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <img src="/@Model.Image" alt="" style="max-height: 100px;" />
                }
                else
                {
                    <span>Нет изображения</span>
                }
            </div>

            <div class="form-group mb-3">
                <label asp-for="Image" class="control-label">Новое изображение</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                <span class="text-muted">Оставьте пустым, чтобы не менять</span>
            </div>

            <div class="form-group">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("ValidationScriptsPartial");
    }
}