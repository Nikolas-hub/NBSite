@using NBSite.Areas.Admin.Models
@model ProductListVM
@{
    ViewData["Title"] = "Управление товарами";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Добавить товар
    </a>
</p>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Поиск по названию или ID" value="@Model.SearchQuery" />
        <button class="btn btn-outline-secondary" type="submit">Найти</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Изображение</th>
            <th>Название</th>
            <th>Цена</th>
            <th>Остаток</th>
            <th>Категория</th>
            <th>Производитель</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items!)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.Image))
                    {
                        <img src="/@item.Image" alt="" style="max-height: 50px;" />
                    }
                </td>
                <td>@item.Name</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.Quantity</td>
                <td>@item.CategoryName</td>
                <td>@item.ManufacturerName</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                        <i class="fas fa-edit me-1"></i>Редактировать
                    </a>
                    <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@item.Id)">
                        <i class="fas fa-trash me-1"></i>Удалить
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.SearchQuery">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить товар?')) {
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("Delete")/' + id;
                form.innerHTML = '@Html.AntiForgeryToken()';
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}