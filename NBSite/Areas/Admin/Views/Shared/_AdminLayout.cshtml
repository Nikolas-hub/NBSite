<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - Админ-панель</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar admin-navbar navbar-expand-lg">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">
                <i class="fas fa-cog me-2"></i>Админ-панель
            </a>
            <a class="navbar-brand" asp-area="Default" asp-controller="Home" asp-action="Index">
                <i class="fas fa-backspace me-1"></i>Главная страница
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarAdmin">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarAdmin">
                <ul class="navbar-nav ms-auto">
                    <!-- или просто navbar-nav, если нужно слева -->
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Products" asp-action="Index">
                            <i class="fas fa-box me-1"></i>Товары
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                            <i class="fas fa-tags me-1"></i>Категории
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Manufacturers" asp-action="Index">
                            <i class="fas fa-industry me-1"></i>Производители
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                            <i class="fas fa-shopping-cart me-1"></i>Заказы
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index">
                            <i class="fas fa-users me-1"></i>Пользователи
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Discounts" asp-action="Index">
                            <i class="fas fa-percent me-1"></i>Акции
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="News" asp-action="Index">
                            <i class="fas fa-newspaper me-1"></i>Новости
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <main class="container mt-3">
        @RenderBody()
    </main>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Разрешаем запятую и точку в валидации чисел
        $.validator.methods.number = function(value, element) {
            return this.optional(element) ||
                /^-?\d+(?:[.,]\d+)?$/.test(value) &&
                !isNaN(parseFloat(value.replace(',', '.')));
        };

        // Перед отправкой формы заменяем точку на запятую в числовых полях
        $('form').on('submit', function() {
            $(this).find('input[type="text"], input[type="number"]').each(function() {
                var $input = $(this);
                var name = $input.attr('name') || '';
                if (name.match(/price|oldprice|volume|weight|quantity|multiplicity/i)) {
                    var value = $input.val();
                    if (value && value.includes('.')) {
                        $input.val(value.replace(/\./g, ','));
                    }
                }
            });
        });
    </script>
</body>
</html>