@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Восстановление пароля";
}

<div class="customer_login mt-10">
    <div class="container">
        <div class="row d-flex align-items-center justify-content-center">
            <div class="col-lg-6 col-md-6">
                <div class="account_form">
                    <h3>Восстановление пароля</h3>
                    <p class="text-muted mb-4">Введите ваш email, и мы отправим вам ссылку для сброса пароля.</p>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        </div>
                    }

                    <form method="post" asp-controller="Account" asp-action="ForgotPassword">
                        @Html.AntiForgeryToken()

                        <div class="default-form-box mb-20">
                            <label asp-for="Email">Email <span>*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="Ваш email">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="login_submit d-flex flex-column">
                            <button class="btn btn-primary btn-lg mb-3" type="submit">
                                <i class="fas fa-envelope me-2"></i>Отправить ссылку
                            </button>

                            <div class="text-center">
                                <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                                    <i class="fas fa-arrow-left me-1"></i>Вернуться ко входу
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* используйте те же стили, что и в Login.cshtml */
    </style>
}