@using NBSite.Models.ViewComponents
@model RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="customer_login mt-10">
    <div class="container">
        <div class="row d-flex align-items-center justify-content-center">
            <div class="col-lg-6 col-md-6">
                <div class="account_form register">
                    <h3>Регистрация</h3>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        </div>
                    }

                    <form method="post" asp-controller="Account" asp-action="Register">
                        @Html.AntiForgeryToken()

                        <div class="default-form-box mb-20">
                            <label asp-for="LastName">Фамилия <span>*</span></label>
                            <input asp-for="LastName" type="text" class="form-control" placeholder="Введите фамилию" autofocus>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        <div class="default-form-box mb-20">
                            <label asp-for="FirstName">Имя <span>*</span></label>
                            <input asp-for="FirstName" type="text" class="form-control" placeholder="Введите имя">
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="default-form-box mb-20">
                            <label asp-for="Email">Email <span>*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="example@mail.com">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="default-form-box mb-20">
                            <label asp-for="Username">Логин (необязательно)</label>
                            <input asp-for="Username" type="text" class="form-control"
                                   placeholder="Оставьте пустым — создадим автоматически">
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="default-form-box mb-20">
                            <label asp-for="Phone">Телефон</label>
                            <input asp-for="Phone" type="tel" class="form-control" placeholder="+7 (123) 456-78-90">
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <!-- Поле Компания -->
                        <div class="default-form-box mb-20">
                            <label asp-for="Company">Компания</label>
                            <input asp-for="Company" type="text" class="form-control" placeholder="Название компании">
                            <span asp-validation-for="Company" class="text-danger"></span>
                        </div>

                        <!-- Поле Город -->
                        <div class="default-form-box mb-20">
                            <label asp-for="CityId">Город</label>
                            <select asp-for="CityId" class="form-control" asp-items="ViewBag.Cities">
                                <option value="">-- Выберите город --</option>
                            </select>
                            <span asp-validation-for="CityId" class="text-danger"></span>
                        </div>

                        <div class="default-form-box mb-20">
                            <label asp-for="Password">Пароль <span>*</span></label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Не менее 6 символов">
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="default-form-box mb-20">
                            <label asp-for="ConfirmPassword">Подтверждение пароля <span>*</span></label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Повторите пароль">
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="login_submit d-flex flex-column">
                            <button class="btn btn-primary btn-lg mb-3" type="submit">
                                <i class="fas fa-user-plus me-2"></i>Зарегистрироваться
                            </button>
                            <div class="form-group mt-3 text-center">
                                <small class="text-muted">
                                    Нажимая кнопку "Зарегистрироваться", вы подтверждаете свое согласие с <a href="/Home/Terms" target="_blank">пользовательским соглашением</a>.
                                </small>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                                    <i class="fas fa-sign-in-alt me-1"></i>Уже есть аккаунт?
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .fas{
            margin-right: 5px;
        }
        .customer_login {
            min-height: calc(100vh - 200px);
            display: flex;
            align-items: center;
        }

        .account_form {
            background: white;
            border-radius: 10px;
            padding: 40px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            border: 1px solid #e9ecef;
        }

            .account_form.register {
                padding-top: 30px;
            }

            .account_form h3 {
                font-size: 1.8rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 30px;
                text-align: center;
                padding-bottom: 15px;
                border-bottom: 2px solid #28a745;
            }

        .default-form-box {
            margin-bottom: 1.5rem;
        }

            .default-form-box label {
                display: block;
                font-weight: 500;
                margin-bottom: 0.5rem;
                color: #495057;
            }

                .default-form-box label span {
                    color: #dc3545;
                }

            .default-form-box input[type="text"],
            .default-form-box input[type="password"],
            .default-form-box input[type="email"],
            .default-form-box input[type="tel"] {
                width: 100%;
                padding: 0.75rem 1rem;
                border: 1px solid #ced4da;
                border-radius: 4px;
                font-size: 1rem;
                transition: border-color 0.3s, box-shadow 0.3s;
            }

            .default-form-box input:focus {
                border-color: #28a745;
                box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
                outline: none;
            }

        .text-danger {
            font-size: 0.875rem;
            margin-top: 0.25rem;
            display: block;
        }

        .btn-primary {
            background-color: #28a745;
            border-color: #28a745;
            padding: 0.75rem 2rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background-color: #218838;
                border-color: #1e7e34;
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            }

        .login_submit a {
            color: #28a745;
            text-decoration: none;
            transition: color 0.3s;
        }

            .login_submit a:hover {
                color: #218838;
                text-decoration: underline;
            }

        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
            padding: 0.75rem 1.25rem;
            border-radius: 4px;
            margin-bottom: 1.5rem;
        }

        /* Адаптивность */
        @@media (max-width: 768px) {
            .account_form {
                padding: 25px;
                margin: 0 15px;
            }

                .account_form h3 {
                    font-size: 1.5rem;
                }

            .login_submit .d-flex {
                flex-direction: column;
                gap: 10px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        // Автофокус на первое поле при загрузке
        document.addEventListener('DOMContentLoaded', function() {
            var lastNameInput = document.getElementById('LastName');
            if (lastNameInput) {
                lastNameInput.focus();
            }
        });

        // Показать/скрыть пароль (одинаковая функция с login)
        function togglePassword() {
            var passwordInput = document.getElementById('Password');
            var toggleIcon = document.getElementById('togglePasswordIcon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        }

        // Функция для подтверждения пароля
        function toggleConfirmPassword() {
            var confirmPasswordInput = document.getElementById('ConfirmPassword');
            var toggleIcon = document.getElementById('toggleConfirmPasswordIcon');

            if (confirmPasswordInput.type === 'password') {
                confirmPasswordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                confirmPasswordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        }

        // Добавление иконок показа/скрытия пароля
        function addPasswordToggles() {
            // Для основного пароля
            var passwordField = document.getElementById('Password');
            if (passwordField) {
                var parent = passwordField.parentElement;
                parent.style.position = 'relative';

                var toggleButton = document.createElement('button');
                toggleButton.type = 'button';
                toggleButton.className = 'btn btn-outline-secondary';
                toggleButton.style.position = 'absolute';
                toggleButton.style.right = '10px';
                toggleButton.style.top = '75%';
                toggleButton.style.transform = 'translateY(-50%)';
                toggleButton.style.border = 'none';
                toggleButton.style.background = 'transparent';
                toggleButton.onclick = togglePassword;

                var icon = document.createElement('i');
                icon.id = 'togglePasswordIcon';
                icon.className = 'fas fa-eye';

                toggleButton.appendChild(icon);
                parent.appendChild(toggleButton);

                // Добавить padding справа для input
                passwordField.style.paddingRight = '40px';
            }

            // Для подтверждения пароля
            var confirmPasswordField = document.getElementById('ConfirmPassword');
            if (confirmPasswordField) {
                var parent = confirmPasswordField.parentElement;
                parent.style.position = 'relative';

                var toggleButton = document.createElement('button');
                toggleButton.type = 'button';
                toggleButton.className = 'btn btn-outline-secondary';
                toggleButton.style.position = 'absolute';
                toggleButton.style.right = '10px';
                toggleButton.style.top = '75%';
                toggleButton.style.transform = 'translateY(-50%)';
                toggleButton.style.border = 'none';
                toggleButton.style.background = 'transparent';
                toggleButton.onclick = toggleConfirmPassword;

                var icon = document.createElement('i');
                icon.id = 'toggleConfirmPasswordIcon';
                icon.className = 'fas fa-eye';

                toggleButton.appendChild(icon);
                parent.appendChild(toggleButton);

                // Добавить padding справа для input
                confirmPasswordField.style.paddingRight = '40px';
            }
        }

        document.addEventListener('DOMContentLoaded', addPasswordToggles);
    </script>

    <partial name="ValidationScriptsPartial" />
}