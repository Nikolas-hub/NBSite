@{
    ViewData["Title"] = "Пароль изменён";
}

<div class="customer_login mt-10">
    <div class="container">
        <div class="row d-flex align-items-center justify-content-center">
            <div class="col-lg-6 col-md-6">
                <div class="account_form text-center">
                    <div class="mb-4">
                        <i class="fas fa-check-circle fa-4x text-success"></i>
                    </div>
                    <h3 class="mb-4">Пароль успешно изменён</h3>
                    <p class="text-muted mb-4">
                        Теперь вы можете войти в систему с новым паролем.
                    </p>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                        <i class="fas fa-sign-in-alt me-2"></i>Войти
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>