<!-- Секция с новыми поступлениями -->
<div class="product-section ">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="section-header mb-4 mt-15">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="section-title">Новые поступления</h2>
                        <a href="@Url.Action("ShowProducts", "Shopping", new { sortOrder = "new" })" class="btn btn-outline-primary">
                            Все новинки <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                    <p class="section-subtitle text-muted">Самые свежие поступления в нашем каталоге</p>
                </div>
            </div>
        </div>

        @if (Model.NewProducts.Any())
        {
            <div class="row">
                @foreach (var product in Model.NewProducts.Take(8))
                {
                    <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 col-12 mb-4">
                        <div class="product-card border-around">
                            <!-- Изображение товара -->
                            <div class="product-img-warp position-relative">
                                <a href="@Url.Action("ShowProduct", "Shopping", new { alias = product.Alias })"
                                   class="product-default-img-link d-block">
                                    <img src="@(product.Thumbnail ?? "/img/no-image.png")"
                                         alt="@product.Name"
                                         class="product-default-img img-fluid">
                                </a>

                                <!-- Бейджи -->
                                <div class="product-badges position-absolute top-0 start-0 p-2">
                                    @if (product.IsNew)
                                    {
                                        <span class="badge bg-success">Новинка</span>
                                    }
                                    @if (product.HasDiscount)
                                    {
                                        <span class="badge bg-danger">-@product.DiscountPercent%</span>
                                    }
                                </div>


                            </div>

                            <!-- Информация о товаре -->
                            <div class="product-default-content p-3">
                                <!-- Название -->
                                <h6 class="product-default-link mb-2">
                                    <a href="@Url.Action("ShowProduct", "Shopping", new { alias = product.Alias })"
                                       class="text-decoration-none text-dark">
                                        @product.Name
                                    </a>
                                </h6>

                                <!-- Категория -->
                                @if (!string.IsNullOrEmpty(product.CategoryName))
                                {
                                    <div class="product-category small text-muted mb-2">
                                        @product.CategoryName
                                    </div>
                                }
                                <div class="product-footer">
                                    <!-- Цена -->
                                    <div class="product-price mb-3">
                                        @if (product.HasDiscount)
                                        {
                                            <div class="price-old text-muted text-decoration-line-through">
                                                @product.FormattedOldPrice
                                            </div>
                                        }
                                        <div class="price-current fw-bold text-primary fs-5">
                                            @product.FormattedPrice
                                        </div>
                                    </div>

                                    <!-- Наличие -->
                                    <div class="product-stock mb-2">
                                        <span class="badge @(product.InStock ? "bg-success" : "bg-danger")">
                                            @product.StockStatus
                                        </span>
                                    </div>
                                    @if (product.InStock)
                                    {
                                        <!-- Блок выбора количества (только для товаров в наличии) -->
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="small">Кол-во:</span>
                                            <div class="input-group input-group-sm" style="width: 120px;">
                                                <button type="button" class="btn btn-outline-secondary"
                                                        onclick="decreaseQuantity(@product.Id)">
                                                    -
                                                </button>
                                                <input type="number" class="form-control text-center"
                                                       id="qty_@product.Id"
                                                       value="@product.Multiplicity"
                                                       min="@product.Multiplicity"
                                                       max="@product.Quantity"
                                                       step="@product.Multiplicity"
                                                       onchange="validateQuantity(@product.Id)">
                                                <button type="button" class="btn btn-outline-secondary"
                                                        onclick="increaseQuantity(@product.Id)">
                                                    +
                                                </button>
                                            </div>
                                        </div>
                                        <!-- Кнопка добавления в корзину с выбранным количеством -->
                                        <button class="btn btn-primary w-100"
                                                onclick="addToCart(@product.Id, document.getElementById('qty_@product.Id').value)">
                                            <i class="fas fa-shopping-cart me-2"></i>В корзину
                                        </button>
                                    }
                                    else
                                    {
                                        <!-- Кнопка для отсутствующего товара (неактивна) -->
                                        <button class="btn btn-primary w-100" disabled>
                                            <i class="fas fa-shopping-cart me-2"></i>Под заказ
                                        </button>
                                    }
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="mb-4">
                    <i class="fas fa-box-open fa-4x text-muted"></i>
                </div>
                <h4 class="mb-3">Новых поступлений пока нет</h4>
                <p class="text-muted mb-4">Скоро мы добавим новые товары</p>
                <a href="@Url.Action("ShowProducts", "Shopping")" class="btn btn-primary">
                    <i class="fas fa-shop me-2"></i>Перейти в каталог
                </a>
            </div>
        }
    </div>
</div>

<!-- Секция с популярными товарами -->
@if (Model.PopularProducts.Any())
{
    <div class="product-section section-top-gap-50 bg-light py-5">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="section-header mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="section-title">Популярные товары</h2>
                            <a href="@Url.Action("ShowProducts", "Shopping", new { sortOrder = "popular" })" class="btn btn-outline-primary">
                                Все популярные <i class="fas fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                        <p class="section-subtitle text-muted">Самые востребованные товары среди наших клиентов</p>
                    </div>
                </div>
            </div>

            <div class="row">
                @foreach (var product in Model.PopularProducts.Take(8))
                {
                    <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 col-12 mb-4">
                        <div class="product-card border-around">
                            <!-- Изображение товара -->
                            <div class="product-img-warp position-relative">
                                <a href="@Url.Action("ShowProduct", "Shopping", new { id = product.Alias })"
                                   class="product-default-img-link d-block">
                                    <img src="@(product.Thumbnail ?? "/img/no-image.png")"
                                         alt="@product.Name"
                                         class="product-default-img img-fluid">
                                </a>

                                <!-- Бейджи -->
                                <div class="product-badges position-absolute top-0 start-0 p-2">
                                    @if (product.IsPopular)
                                    {
                                        <span class="badge bg-warning text-dark">Топ продаж</span>
                                    }
                                    @if (product.HasDiscount)
                                    {
                                        <span class="badge bg-danger">-@product.DiscountPercent%</span>
                                    }
                                    @if (product.IsNew)
                                    {
                                        <span class="badge bg-success">Новинка</span>
                                    }
                                </div>


                            </div>

                            <!-- Информация о товаре -->
                            <div class="product-default-content p-3">
                                <!-- Название -->
                                <h6 class="product-default-link mb-2">
                                    <a href="@Url.Action("ShowProduct", "Shopping", new { id = product.Alias })"
                                       class="text-decoration-none text-dark">
                                        @product.Name
                                    </a>
                                </h6>

                                <!-- Категория -->
                                @if (!string.IsNullOrEmpty(product.CategoryName))
                                {
                                    <div class="product-category small text-muted mb-2">
                                        @product.CategoryName
                                    </div>
                                }

                                <!-- Производитель -->
                                @if (!string.IsNullOrEmpty(product.ManufacturerName))
                                {
                                    <div class="product-manufacturer small text-muted mb-2">
                                        Производитель: @product.ManufacturerName
                                    </div>
                                }
                                <div class="product-footer">
                                    <!-- Цена -->
                                    <div class="product-price mb-3">
                                        @if (product.HasDiscount)
                                        {
                                            <div class="price-old text-muted text-decoration-line-through">
                                                @product.FormattedOldPrice
                                            </div>
                                        }
                                        <div class="price-current fw-bold text-primary fs-5">
                                            @product.FormattedPrice
                                        </div>
                                    </div>

                                    <!-- Наличие -->
                                    <div class="product-stock mb-2">
                                        <span class="badge @(product.InStock ? "bg-success" : "bg-danger")">
                                            @product.StockStatus
                                        </span>
                                    </div>

                                    <!-- Кнопка в корзину -->
                                    <button class="btn btn-primary w-100"
                                            onclick="addToCart(@product.Id, @product.Multiplicity)"
                                            @(!product.InStock ? "disabled" : "")>
                                        <i class="fas fa-shopping-cart me-2"></i>В корзину
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
<!-- Секция с новостями -->
@if (Model.LatestNews.Any())
{
    <div class="news-section section-top-gap-50 py-5">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="section-header mb-4">
                        <h2 class="section-title">Последние новости</h2>
                        <p class="section-subtitle text-muted">Актуальные новости и обновления</p>
                    </div>
                </div>
            </div>

            <div class="row">
                @foreach (var news in Model.LatestNews.Take(3))
                {
                    <div class="col-lg-4 col-md-6 col-12 mb-4">
                        <div class="news-card card h-100 border-0 shadow-sm">
                            @if (!string.IsNullOrEmpty(news.Thumbnail))
                            {
                                <img src="@Url.Content("~/" + news.Thumbnail)" class="card-img-top" alt="@news.Title" style="height: 200px; object-fit: cover;">
                            }
                            else if (!string.IsNullOrEmpty(news.Image))
                            {
                                <img src="@Url.Content("~/" + news.Image)" class="card-img-top" alt="@news.Title" style="height: 200px; object-fit: cover;">
                            }
                            <div class="card-body">
                                <div class="news-meta text-muted small mb-2">
                                    <i class="far fa-calendar me-1"></i>@news.FormattedDate
                                </div>
                                <h5 class="card-title">
                                    <a href="@Url.Action("Details", "News", new { id = news.Id, alias = news.Alias })"
                                       class="text-decoration-none text-dark">
                                        @news.Title
                                    </a>
                                </h5>
                                @if (!string.IsNullOrEmpty(news.IntroText))
                                {
                                    <p class="card-text text-muted">@news.IntroText</p>
                                }
                            </div>
                            <div class="card-footer bg-transparent border-top-0">
                                <a href="@Url.Action("Details", "News", new { id = news.Id, alias = news.Alias })"
                                   class="btn btn-outline-primary">
                                    Читать далее <i class="fas fa-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="row mt-4">
                <div class="col-12 text-center">
                    <a href="@Url.Action("Index", "News")" class="btn btn-primary">
                        <i class="fas fa-newspaper me-2"></i>Все новости
                    </a>
                </div>
            </div>
        </div>
    </div>
}

