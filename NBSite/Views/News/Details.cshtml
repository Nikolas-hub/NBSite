@model Domain.Entities.ContentNews

@{
    Layout = "_Layout";
    ViewData["Title"] = Model.MetaTitle ?? Model.Name;
    ViewData["MetaKeywords"] = Model.MetaKeywords;
    ViewData["MetaDescription"] = Model.MetaDescription;
}

<!-- Хлебные крошки -->
<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb-wrapper">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Главная</a></li>
                            <li class="breadcrumb-item"><a href="@Url.Action("Index", "News")">Новости</a></li>
                            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Детальная новость -->
<div class="news-detail-section py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-10 offset-lg-1">
                <article class="news-article">
                    <!-- Заголовок -->
                    <h1 class="news-title mb-3">@Model.Name</h1>

                    <!-- Мета-информация -->
                    <div class="news-meta d-flex align-items-center text-muted mb-4">
                        <i class="far fa-calendar me-2"></i>
                        <span>@Model.Date.ToString("dd MMMM yyyy")</span>
                    </div>

                    <!-- Изображение -->
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <div class="news-image mb-4">
                            <img src="@Url.Content("~/" + Model.Image)" alt="@Model.Name" class="img-fluid rounded">
                        </div>
                    }

                    <!-- Полный текст новости (выводится как HTML) -->
                    @if (!string.IsNullOrEmpty(Model.Content))
                    {
                        <div class="news-content">
                            @Html.Raw(Model.Content)
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Содержание новости отсутствует.</p>
                    }

                    <!-- Кнопка возврата к списку -->
                    <div class="mt-5">
                        <a href="@Url.Action("Index", "News")" class="btn btn-outline-primary">
                            <i class="fas fa-arrow-left me-2"></i>Все новости
                        </a>
                    </div>
                </article>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .breadcrumb-section {
            background-color: #f8f9fa;
            padding: 15px 0;
            margin-bottom: 20px;
        }

        .news-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: #333;
            line-height: 1.3;
        }

        .news-meta {
            font-size: 0.95rem;
        }

        .news-image img {
            max-height: 500px;
            width: 100%;
            object-fit: cover;
        }

        .news-content {
            font-size: 1.1rem;
            line-height: 1.7;
            color: #444;
        }

            .news-content p {
                margin-bottom: 1.5rem;
            }

            .news-content h2, .news-content h3 {
                margin-top: 2rem;
                margin-bottom: 1rem;
            }

            .news-content img {
                max-width: 100%;
                height: auto;
                border-radius: 8px;
                margin: 1.5rem 0;
            }
        /* Адаптивность */
        @@media (max-width: 768px) {
            .news-title {
                font-size: 1.8rem;
            }

            .news-content {
                font-size: 1rem;
            }
        }
    </style>
}