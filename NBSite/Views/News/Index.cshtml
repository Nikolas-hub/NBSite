@model IEnumerable<Domain.Entities.ContentNews>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Новости";
}

<!-- Хлебные крошки (мобильная версия) -->
<div class="breadcrumb-section d-block d-md-none">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb-wrapper">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">Главная</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Новости</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Заголовок страницы (десктоп) -->
<div class="page-header d-none d-md-block mt-4">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h1 class="page-title">Новости</h1>
                <p class="page-subtitle text-muted">Актуальные события и обновления</p>
            </div>
        </div>
    </div>
</div>

<!-- Список новостей -->
<div class="news-list-section py-5">
    <div class="container">
        @if (Model.Any())
        {
            <div class="row">
                @foreach (var news in Model)
                {
                    <div class="col-lg-4 col-md-6 col-12 mb-4">
                        <div class="news-card card h-100 border-0 shadow-sm">
                            @if (!string.IsNullOrEmpty(news.Image))
                            {
                                <img src="@news.Image" class="card-img-top" alt="@news.Name" style="height: 200px; object-fit: cover;">
                            }
                            <div class="card-body">
                                <div class="news-meta text-muted small mb-2">
                                    <i class="far fa-calendar me-1"></i>@news.Date.ToString("dd MMMM yyyy")
                                </div>
                                <h5 class="card-title">
                                    <a href="@Url.Action("Details", "News", new { id = news.Id, alias = news.Alias })"
                                       class="text-decoration-none text-dark">
                                        @news.Name
                                    </a>
                                </h5>
                                @if (!string.IsNullOrEmpty(news.Introtext))
                                {
                                    <p class="card-text text-muted">@news.Introtext</p>
                                }
                            </div>
                            <div class="card-footer bg-transparent border-top-0">
                                <a href="@Url.Action("Details", "News", new { id = news.Id, alias = news.Alias })"
                                   class="btn btn-outline-primary">
                                    Читать далее <i class="fas fa-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Здесь можно добавить пагинацию (опционально) -->
        }
        else
        {
            <div class="text-center py-5">
                <div class="mb-4">
                    <i class="fas fa-newspaper fa-4x text-muted"></i>
                </div>
                <h4 class="mb-3">Пока нет новостей</h4>
                <p class="text-muted mb-4">Скоро мы опубликуем новые материалы</p>
                <a href="/" class="btn btn-primary">
                    <i class="fas fa-home me-2"></i>На главную
                </a>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .page-header {
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: #333;
        }

        .page-subtitle {
            font-size: 1.1rem;
            color: #6c757d;
        }
        /* Стили карточек новостей (повтор из главной) */
        .news-card {
            transition: all 0.3s ease;
        }

            .news-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            }

        .news-meta {
            font-size: 0.85rem;
        }
    </style>
}