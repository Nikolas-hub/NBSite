
<footer class="footer-section section-top-gap-100">
    <!-- Верхняя часть футера с основной информацией -->
    <div class="footer-top section-inner-bg pt-80 pb-60">
        <div class="container">
            <div class="row">
                <!-- Логотип и название компании -->
                <div class="col-lg-3 col-md-6 col-sm-6 mb-30">
                    <div class="footer-widget">
                        <div class="footer-logo mb-25">
                            <a href="/Home/Index">
                                <img src="@Url.Content(AppConfig.Footer.LogoPath)" alt="@AppConfig.Company.CompanyName" class="img-fluid">
                            </a>
                        </div>

                    </div>
                </div>

                <div class="col-lg-2 col-md-6 col-sm-6 mb-30">
                    <div class="footer-widget">
                        <h6 class="footer-widget-title mb-25">Магазин</h6>
                        <ul class="footer-links">
                            <li><a href="/Shopping/ShowProducts">Каталог товаров</a></li>
                            <li><a href="/Shopping/ShowProducts?sortOrder=new">Новинки</a></li>
                            <li><a href="/Catalog/Sale">Акции</a></li>
                            <li><a href="@Url.Action("ShowProducts", "Shopping", new { sortOrder = "popular" })">Топ продаж</a></li>
                        </ul>
                    </div>
                </div>


                <div class="col-lg-2 col-md-6 col-sm-6 mb-30">
                    <div class="footer-widget">
                        <h6 class="footer-widget-title mb-25">Покупателям</h6>
                        <ul class="footer-links">
                            <li><a href="/Home/Delivery">Доставка</a></li>
                            <li><a href="/Home/HowToBuy">Как купить?</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 col-sm-6 mb-30">
                    <div class="footer-widget">
                        <h6 class="footer-widget-title mb-25">Компания</h6>
                        <ul class="footer-links">
                            <li><a href="/Home/About">О нас</a></li>
                            <li><a href="/Home/Contacts">Контакты</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Контакты и поддержка – данные из AppConfig -->
                <div class="col-lg-3 col-md-6 col-sm-6 mb-30">
                    <div class="footer-widget">
                        <h6 class="footer-widget-title mb-25">Контакты</h6>
                        <div class="footer-contact-info">
                            <div class="contact-item mb-20">
                                <div class="contact-icon mr-15">
                                    <i class="fas fa-phone-alt"></i>
                                </div>
                                <div class="contact-text">
                                    <span>Телефон</span>
                                    <a href="tel:@AppConfig.Company.CompanyPhoneShort" class="d-block">@AppConfig.Company.CompanyPhone</a>
                                </div>
                            </div>
                            <div class="contact-item mb-20">
                                <div class="contact-icon mr-15">
                                    <i class="fas fa-envelope"></i>
                                </div>
                                <div class="contact-text">
                                    <span>Email</span>
                                    <a href="mailto:@AppConfig.Company.CompanyEmail">@AppConfig.Company.CompanyEmail</a>
                                </div>
                            </div>
                            <div class="contact-item mb-20">
                                <div class="contact-icon mr-15">
                                    <i class="fab fa-telegram-plane"></i>
                                </div>
                                <div class="contact-text">
                                    <span>Telegram</span>
                                    @{
                                        var telegramLink = AppConfig.Company.CompanyTelegram;
                                        if (!string.IsNullOrEmpty(telegramLink) && !telegramLink.StartsWith("http"))
                                        {
                                            telegramLink = "https://t.me/" + telegramLink.TrimStart('@');
                                        }
                                    }
                                    <a href="@telegramLink" target="_blank" rel="noopener noreferrer">Telegram</a>
                                </div>
                            </div>
                            <div class="contact-item mb-20">
                                <div class="contact-icon mr-15">
                                    <i class="fas fa-map-marker-alt"></i>
                                </div>
                                <div class="contact-text">
                                    <span>Адрес</span>
                                    <p>@AppConfig.Footer.Address</p>
                                </div>
                            </div>
                            @* <div class="contact-item">
                                <div class="contact-icon mr-15">
                                    <i class="fas fa-clock"></i>
                                </div>
                                <div class="contact-text">
                                    <span>Режим работы</span>
                                    <p>Пн-Пт: 9:00-18:00</p>
                                    <p>Сб-Вс: Выходной</p>
                                </div>
                            </div> *@
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Нижняя часть футера -->
    <div class="footer-bottom py-20">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 col-md-6">
                    <div class="copyright-text">
                        <p>@AppConfig.Company.CompanyName &copy; @AppConfig.Footer.FoundingYear — @DateTime.Now.Year</p>
                        <div class="mt-10">
                            <a href="/Home/Terms">Пользовательское соглашение</a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6">
                </div>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer-section {
        background-color: #f8f9fa;
    }

    .footer-top {
        background-color: #fff;
        border-top: 1px solid #eee;
    }

    .footer-widget-title {
        font-size: 16px;
        font-weight: 600;
        color: #333;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .footer-links li {
        margin-bottom: 10px;
    }

    .footer-links a {
        color: #666;
        transition: color 0.3s;
        text-decoration: none;
    }

        .footer-links a:hover {
            color: #007bff;
            text-decoration: underline;
        }

    .footer-about p {
        color: #666;
        line-height: 1.6;
        font-size: 10px;
    }

    .contact-item {
        display: flex;
        align-items: flex-start;
        margin-bottom: 15px;
    }

    .contact-icon {
        color: #007bff;
        font-size: 18px;
        width: 24px;
        text-align: center;
    }

    .contact-text span {
        display: block;
        font-weight: 600;
        color: #333;
        font-size: 14px;
    }

    .contact-text a,
    .contact-text p {
        color: #666;
        font-size: 14px;
        margin: 0;
    }

    .contact-text small {
        color: #999;
        font-size: 12px;
    }

    .footer-bottom {
        background-color: #343a40;
        color: #fff;
    }

    .copyright-text a {
        color: #ccc;
        font-size: 14px;
    }

        .copyright-text a:hover {
            color: #fff;
            text-decoration: underline;
        }

    .payment-methods {
        color: #ccc;
    }

    .payment-icon {
        font-size: 24px;
        margin-right: 10px;
        color: #666;
        transition: color 0.3s;
    }

        .payment-icon:hover {
            color: #fff;
        }

    .developers a {
        color: #6c757d;
    }

        .developers a:hover {
            color: #fff;
            text-decoration: underline;
        }



    .payment-methods {
        text-align: left !important;
        margin-top: 20px;
    }

    
</style>