<script src="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0.36/dist/fancybox/fancybox.umd.js"></script>
<script>
    Fancybox.bind('[data-fancybox]', {
        // Разрешаем увеличение до 500% от оригинала
        zoom: {
            max: 5
        },
        // Включаем зум колёсиком мыши
        wheel: "zoom",
        // Включаем зум по двойному клику
        dblclick: true,
        // При открытии показываем изображение в оригинальном размере (маленьком)
        initialScale: 1,
        // Настраиваем панель инструментов – оставляем только нужные кнопки
        Toolbar: {
            display: {
                middle: ["zoomIn", "zoomOut", "toggle1to1"]
            }
        },
        // Если изображение меньше окна, разрешаем увеличивать всё равно
        // (параметр minScale не влияет на зум вверх)
        minScale: 0.5
    });
</script>

