            }

        /* Адаптивность */
        @@media (max-width: 768px) {
            .product-img-warp {
                height: 200px;
            }

            .product-card {
                margin-bottom: 20px;
            }

            .sidebar-section {
                margin-bottom: 20px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        // Инициализация при загрузке страницы
        document.addEventListener('DOMContentLoaded', function() {
            // Функция для установки значения в селектах сортировки
            function initSelect(selectId) {
                var select = document.getElementById(selectId);
                if (select) {
                    var options = select.getElementsByTagName('option');
                    for (var i = 0; i < options.length; i++) {
                        if (options[i].getAttribute('data-selected') === 'True') {
                            select.value = options[i].value;
                            break;
                        }
                    }
                }
            }

            // Инициализация чекбокса "в наличии"
            var inStockCheckbox = document.getElementById('inStockFilter');
            if (inStockCheckbox) {
                var urlParams = new URLSearchParams(window.location.search);
                // Если параметр inStock отсутствует, то сервер по умолчанию считает его true,
                // поэтому чекбокс должен быть отмечен.
                if (urlParams.has('inStock')) {
                    inStockCheckbox.checked = (urlParams.get('inStock') === 'true');
                } else {
                    inStockCheckbox.checked = true; // значение по умолчанию (как на сервере)
                }
            }

            // Инициализация селектов сортировки
            initSelect('mobileSortSelect');
            initSelect('desktopSortSelect');
        });

        // Основная функция применения фильтров (сортировка, наличие, категории)
        function applyFilters() {
            var url = new URL(window.location.href);
            var params = new URLSearchParams(url.search);

            // Сортировка
            var sortSelect = document.getElementById('desktopSortSelect') || document.getElementById('mobileSortSelect');
            if (sortSelect && sortSelect.value) {
                params.set('sortOrder', sortSelect.value);
            }

            // Наличие – всегда явно true/false
            var inStockFilter = document.getElementById('inStockFilter');
            if (inStockFilter) {
                params.set('inStock', inStockFilter.checked ? 'true' : 'false');
            }

            // Категории (через чекбоксы)
            var categoryCheckboxes = document.querySelectorAll('input[name="categoryIds"]:checked');
            var categoryIds = Array.from(categoryCheckboxes).map(cb => cb.value);
            if (categoryIds.length > 0) {
                params.set('categoryIds', categoryIds.join(','));
            } else {
                params.delete('categoryIds');
            }

            // Сбрасываем поля произвольной цены (они применяются отдельно)
            params.delete('minPrice');
            params.delete('maxPrice');

            params.set('page', '1');
            window.location.href = url.pathname + '?' + params.toString();
        }

        // Функция применения фильтра по цене (произвольный диапазон)
        function applyCustomPriceFilter() {
            var minPrice = document.getElementById('minPrice').value;
            var maxPrice = document.getElementById('maxPrice').value;
            var url = new URL(window.location.href);
            var params = new URLSearchParams(url.search);

            if (minPrice) {
                params.set('minPrice', minPrice);
            } else {
                params.delete('minPrice');
            }
            if (maxPrice) {
                params.set('maxPrice', maxPrice);
            } else {
                params.delete('maxPrice');
            }

            // Сохраняем категории, сортировку, наличие
            var categoryCheckboxes = document.querySelectorAll('input[name="categoryIds"]:checked');
            var categoryIds = Array.from(categoryCheckboxes).map(cb => cb.value);
            if (categoryIds.length > 0) {
                params.set('categoryIds', categoryIds.join(','));
            } else {
                params.delete('categoryIds');
            }

            var sortSelect = document.getElementById('desktopSortSelect') || document.getElementById('mobileSortSelect');
            if (sortSelect && sortSelect.value) {
                params.set('sortOrder', sortSelect.value);
            }

            var inStockFilter = document.getElementById('inStockFilter');
            if (inStockFilter) {
                params.set('inStock', inStockFilter.checked ? 'true' : 'false');
            }

            params.set('page', '1');
            window.location.href = url.pathname + '?' + params.toString();
        }

        // Сброс всех фильтров
        function resetFilters() {
            var url = new URL(window.location.href);
            var params = new URLSearchParams();

            // Сохраняем только категорию (если есть) и поисковый запрос
            var categoryAlias = '@(Model.Category?.Alias ?? "")';
            if (categoryAlias) {
                params.set('categoryAlias', categoryAlias);
            }

            if ('@Model.Query') {
                params.set('query', '@Model.Query');
            }

            // Устанавливаем фильтр "в наличии" по умолчанию (включён)
            params.set('inStock', 'true');

            window.location.href = url.pathname + '?' + params.toString();
        }

        // Остальные вспомогательные функции (увеличение/уменьшение количества, добавление в корзину и т.д.)
        // Они остаются без изменений.
        function increaseQuantity(productId) {
            var input = document.getElementById('qty_' + productId);
            if (!input) return;
            var max = parseInt(input.max);
            var step = parseInt(input.step);
            var current = parseInt(input.value) || 0;
            if (current + step <= max) {
                input.value = current + step;
            }
        }

        function decreaseQuantity(productId) {
            var input = document.getElementById('qty_' + productId);
            if (!input) return;
            var min = parseInt(input.min);
            var step = parseInt(input.step);
            var current = parseInt(input.value) || 0;
            if (current - step >= min) {
                input.value = current - step;
            }
        }

        function validateQuantity(productId) {
            var input = document.getElementById('qty_' + productId);
            if (!input) return;
            var min = parseInt(input.min);
            var max = parseInt(input.max);
            var step = parseInt(input.step);
            var value = parseInt(input.value);

            if (isNaN(value) || value < min) {
                input.value = min;
            } else if (value > max) {
                input.value = max;
            } else if (value % step !== 0) {
                input.value = Math.round(value / step) * step;
            }
        }

        function addToCart(productId, quantity) {
            fetch('@Url.Action("AddToBasket", "Shopping")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: new URLSearchParams({
                    ProductId: productId,
                    Quantity: quantity || 1
                })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('Товар добавлен в корзину', 'success');
                        updateCartCount(data.cartItemCount, data.cartTotal);
                    } else {
                        showNotification(data.message || 'Ошибка', 'error');
                    }
                })
                .catch(error => showNotification('Ошибка: ' + error.message, 'error'));
        }
        

        function showNotification(message, type) {
            var notification = document.createElement('div');
            notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show`;
            notification.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
            notification.innerHTML = `
                    ${message}
                    <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
                `;
            document.body.appendChild(notification);
            setTimeout(function() {
                if (notification.parentElement) {
                    notification.remove();
                }
            }, 5000);
        }

        
    </script>
}