name: dockercompose2546442028640338108
services:
  nbsite:
    build:
      context: C:\Users\n.kleba\source\repos\NBSite
      dockerfile: Dockerfile
    container_name: nbsite
    depends_on:
      postgres:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      ASPNETCORE_URLS: http://+:8080
      Project__Database__ConnectionString: Host=postgres;Database=nbshop;Username=postgres;Password=admin
    networks:
      app-network: null
    ports:
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: bind
        source: C:\Users\n.kleba\source\repos\NBSite\NBSite\wwwroot
        target: /app/wwwroot
        bind: {}
      - type: bind
        source: C:\Users\n.kleba\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\n.kleba\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\n.kleba\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\n.kleba\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind: {}
  nginx:
    container_name: nginx
    depends_on:
      nbsite:
        condition: service_started
        required: true
    image: nginx:1.21-alpine
    networks:
      app-network: null
    ports:
      - mode: ingress
        target: 80
        published: "80"
        protocol: tcp
      - mode: ingress
        target: 443
        published: "443"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: bind
        source: C:\Users\n.kleba\source\repos\NBSite\nginx.conf
        target: /etc/nginx/conf.d/default.conf
        bind: {}
      - type: bind
        source: /etc/letsencrypt
        target: /etc/nginx/ssl
        read_only: true
        bind: {}
  postgres:
    container_name: postgres
    environment:
      POSTGRES_DB: nbshop
      POSTGRES_PASSWORD: admin
      POSTGRES_USER: postgres
    image: postgres:18
    networks:
      app-network: null
    ports:
      - mode: ingress
        target: 5432
        published: "5432"
        protocol: tcp
    restart: unless-stopped
    volumes:
      - type: volume
        source: postgres_data
        target: /var/lib/postgresql/data
        volume: {}
networks:
  app-network:
    name: dockercompose2546442028640338108_app-network
    driver: bridge
volumes:
  postgres_data:
    name: dockercompose2546442028640338108_postgres_data